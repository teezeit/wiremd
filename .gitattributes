# Keep markdown files LF on Windows checkouts so log parsers (review-gate
# test, build-review-log, flag-review) see consistent line endings.
*.md text eol=lf

# Preserve CRLF for the fixture that exists *to test* CRLF handling.
packages/core/tests/fixtures/regressions/formatting/crlf-line-endings.md text eol=crlf
