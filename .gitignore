# Dependencies
node_modules/
yarn.lock

# Build outputs
dist/
build/
*.tsbuildinfo

# Test coverage
coverage/
.nyc_output/

# IDE
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.local
.env.*.local

# Generated HTML output from CLI
extensions/skills/**/*.html

# Temporary
tmp/
temp/
*.tmp
*.pid

# OS
.DS_Store
Thumbs.db

# Built VS Code extension package
extensions/vscode/*.vsix

# Bundle artifacts — copied from apps/docs/ and extensions/skills/ by the bundle script
# (regenerated on every `pnpm --filter wiremd-preview run bundle`; source of truth is apps/docs/)
extensions/vscode/docs/
extensions/vscode/skills/

# VitePress cache
apps/docs/.vitepress/cache/

# Turborepo per-package cache
.turbo/

# Generated skill zip (built on release, not checked in)
wireframe-skill.zip

# Release artifacts — uploaded to GitHub Releases, not committed
# (extensions/skills/wireframe/bin/wiremd.js stays committed for the plugin)
releases/

# Snapshot review tool: REVIEW.html is regenerated on `pnpm review` and ignored.
# REVIEW_LOG.md is committed — it's the source of truth for visual review verdicts,
# enforced by tests/review-gate.test.ts (fails on any ⏳ row).
packages/core/tests/fixtures/REVIEW.html
.vercel
