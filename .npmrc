# Force pnpm to install peer dependencies automatically.
# Pinning this avoids ERR_PNPM_LOCKFILE_CONFIG_MISMATCH when developers
# have different `pnpm config` defaults (e.g. legacy `auto-install-peers=false`
# from older pnpm installs) than CI, which uses pnpm's modern default of `true`.
auto-install-peers=true
