# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# Set to 1 to allow all origins (never use in production)
# ALLOW_ALL_ORIGINS=1

# Postgres connection string (leave unset to use in-memory PGlite for local dev)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
