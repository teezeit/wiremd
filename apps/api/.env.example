# ===== Database =====
#
# Local development (default — start with `pnpm --filter wiremd-api run db:up`):
DATABASE_URL=postgres://wiremd:wiremd@localhost:5432/wiremd

#
# Production / staging — Supabase Supavisor pooler URL (port 6543, transaction mode):
# Project Settings → Database → Connection string → "Transaction" mode.
# DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#
# Leave DATABASE_URL unset to use the in-memory PGlite fallback (no docker, no setup,
# data does not persist).

# ===== Local dev server =====
PORT=3030

# ===== CORS =====
# Set to "1" to allow any origin in CORS — local debugging only, never in production.
ALLOW_ALL_ORIGINS=
