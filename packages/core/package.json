{
  "name": "@eclectic-ai/wiremd",
  "version": "0.4.1",
  "description": "Text-first UI design tool - Create wireframes and mockups using Markdown syntax",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./parser": {
      "types": "./dist/parser/index.d.ts",
      "import": "./dist/parser.js",
      "require": "./dist/parser.cjs"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer.js",
      "require": "./dist/renderer.cjs"
    }
  },
  "bin": {
    "wiremd": "./bin/wiremd.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "version": "node ../../scripts/sync-versions.mjs && git add ../../extensions/vscode/package.json ../../extensions/skills/wireframe/.claude-plugin/plugin.json",
    "build": "tsc && vite build",
    "dev": "vite build --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist node_modules",
    "publish:npm": "npm publish --access public",
    "review": "node --loader ./scripts/svg-raw-loader.mjs --import tsx scripts/build-review-page.ts && open tests/fixtures/REVIEW.html",
    "review:log": "tsx scripts/build-review-log.ts",
    "review:flag": "tsx scripts/flag-review.ts",
    "review:refresh": "pnpm run review:log && pnpm run test -- tests/fixtures.test.ts -u && pnpm run review:flag --snapshot-changes"
  },
  "dependencies": {
    "@tabler/icons": "^3.41.1",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-to-markdown": "^2.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.4",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.19.24",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.54.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.4",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/teezeit/wiremd.git",
    "directory": "packages/core"
  },
  "homepage": "https://teezeit.github.io/wiremd/",
  "bugs": {
    "url": "https://github.com/teezeit/wiremd/issues"
  },
  "keywords": [
    "markdown",
    "wireframe",
    "mockup",
    "parser",
    "ui-design",
    "prototyping",
    "text-based",
    "design-tool",
    "html",
    "renderer"
  ],
  "author": "Tobias Hoelzer <tobias@wejam.ai>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
