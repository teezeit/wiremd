{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["transit"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["transit"],
      "inputs": ["src/**", "tests/**", ".eslintrc*", "eslint.config*"],
      "outputs": []
    },
    "publish:npm": {
      "dependsOn": ["build", "test"],
      "cache": false
    }
  }
}
